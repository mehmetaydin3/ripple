{
  "name": "ripple",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "frontend",
    "api",
    "shared",
    "workers"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=api\" \"npm run dev --workspace=frontend\"",
    "dev:api": "npm run dev --workspace=api",
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:workers": "npm run dev --workspace=workers",
    "build": "npm run build --workspace=shared && npm run build --workspace=api && npm run build --workspace=frontend",
    "db:migrate": "npm run db:migrate --workspace=api",
    "db:seed": "npm run db:seed --workspace=api",
    "db:studio": "npm run db:studio --workspace=api"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
